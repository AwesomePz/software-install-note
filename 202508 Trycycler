#!/usr/bin/perl -w
use strict;
use File::Basename;

#======================================================
my $usage = <<USAGE
Usage:$0 <Sample> <circular state> <circular dir> <ourdir>
USAGE
die $usage if @ARGV != 4;
#=======================
my ($sample,$cir_stat,$cir_dir,$outdir) = @ARGV;
my ($dir,$stat,$seq,@seq,%seq,%length,$length);
open Stat,"$cir_stat" or die "Can't open $cir_stat ~~~\n";
open OUT,">$outdir/$sample.Check.Circular.stat";
open OUT1,">$outdir/$sample.OldID2NewID\n";
print OUT1 "OldID\tNewID\n";
$stat = "$sample\t";
while(<Stat>){
	chomp;
	my @line = split /\s+/,$_;
	if($line[1] =~ /linear/){
		$seq = "$cir_dir/$line[0].fa";
		$length = &Fasta($seq,"linear",\%seq);
	}
	if($line[1] =~ /circular/){
		$seq = "$cir_dir/$line[0].fa.cut.fa";
		$length = &Fasta($seq,"circular",\%seq);
	}
	#$stat .= "$line[0]\t$length\t$line[1]\n\t";
}
close(Stat);

open ALL,">$outdir/$sample.Assembly.Circular.fasta";
my ($seq_id,$seq_num,$tag,$pls_id,$pls_num);
foreach my $id (sort {$length{$b} <=> $length{$a}} keys %length ){
	($seq_id,$tag) =  (split /\s+/,$id);
	$seq_num ++;
	$seq_id = "Contig_$seq_num $tag";
	print OUT1 "$id\t$seq_id\n";
	print ALL ">",$seq_id,"\n",$seq{$id},"\n";
	$stat .= "Contig_$seq_num:$tag:$length{$id};";
}
chop($stat);
$stat .= "\t$outdir/$sample.Assembly.Circular.fasta\n";
print OUT $stat;
close(ALL);
close OUT1;
#==================
sub Fasta{
        my ($file,$tag) = @_;
        my ($id,$seq,$length);
        open IN,"$file" or die "$file is not exist";
        $/=">";
        <IN>;
        while(<IN>){
                chomp;
                my @line =split /\n/,$_;
                $id = (split / /,$line[0])[0];
		$id = "$id $tag";
                shift @line;
                $seq = join '',@line;
                $seq{$id} = $seq;
		$length  = length $seq;
		$length{$id} = $length;
        }
        $/="\n";
        close(IN);
	return $length;
}
