# 下载checkm2
cd drep/
mkdir checkm2
wget -c https://github.com/chklovski/CheckM2/archive/refs/tags/1.1.0.tar.gz #如果下载太慢可以先下载到本地然后传输至linux
tar -xvzf 1.1.0.tar.gz --strip-components=1 -C checkm2
mv 1.1.0.tar.gz checkm2
cd checkm2
mamba install -c conda-forge -c bioconda -c defaults \
  scikit-learn=1.6.1 \
  diamond=2.1.11 \
  tensorflow=2.17 \
  numpy=2.3.0 \
  lightgbm \
  pandas \
  scipy \
  prodigal=2.6.3 \
  setuptools \
  requests \
  packaging \
  tqdm #因为下载checkm2删除了fig2dev、jpeg、xfig，可能导致mummer无法使用
python setup.py install
wget -c https://zenodo.org/records/14897628 #下载DIAMOND数据库 #如果下载太慢可以先下载到本地然后传输至linux
tar -xvzf checkm2*z --strip-components=1 -C CheckM2_database
mv checkm2_database.tar.gz CheckM2_database
vim ~/.bashrc
# 将以下内容添加至~/.bashrc
# checkM2
export CHECKM2DB=/dellfsqd2/ST_OCEAN/USER/zengpeiyun/software/drep/checkm2/CheckM2_database/uniref100.KO.1.dmnd
##
source ~/.bashrc

